# Telegram bot notifications
# Create a bot via @BotFather on Telegram, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SQLite database path (inside the Docker volume — do not change unless you know what you're doing)
DATABASE_URL=sqlite:////app/data/click125.db

# Note: the 'cloudflared' external Docker network must exist on your server before deploying.
# Run once: docker network create cloudflared
# Then connect your cloudflared container: docker network connect cloudflared <container-name>
