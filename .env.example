# Telegram bot notifications
# Create a bot via @BotFather on Telegram, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SQLite database path (inside the Docker volume — do not change unless you know what you're doing)
DATABASE_URL=sqlite:////app/data/click125.db

# CORS allowed origins (comma-separated). Use * for open access on a local network.
# For a public server, set to your domain: https://your-domain.com
ALLOWED_ORIGINS=*
